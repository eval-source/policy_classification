# secrets / env — NEVER commit (holds the Tinker API key)
.env

# python
.venv/
__pycache__/
*.pyc
*.pyo

# os
.DS_Store

# local Claude settings (machine-specific permissions)
.claude/settings.local.json

# large third-party reference PDFs (keep CLAUDE.md which cites them)
docs/refs/*.pdf

# transient eval prediction dumps (regenerable; overwritten each run)
results/preds_*.jsonl
results/preds_runs/

# NOTE: datasets ARE published now (synthetic = ours; real = open HF sources — see DATA_SOURCES.md
# for credits/licenses). Synthetic IT contains fake secret-FORMAT strings; regenerable via
# data/it/generate.py. The real-password audit file below stays OUT.

# SFT/training data (derived; regenerable via train/build_sft_data.py)
train/*.jsonl

# training run artifacts (checkpoints are on Tinker; logs may echo fake-secret examples)
train/runs/

# label-audit queue: contains real-data text snippets (PII / secrets)
results/label_audit.jsonl

# co-evolution: frozen anchor + per-round candidate pools (derived eval artifacts; regenerable) —
# kept out to reduce clutter (the core train/val/test datasets ARE published)
data/*/anchor/
data/*/coevolve/
